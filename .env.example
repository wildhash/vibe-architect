# Vibe Architect — Environment Variables

# ── LiveKit ──────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-livekit-host.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
# Pre-generated dev token (lk token create --identity dj1 --room vibe-room)
LIVEKIT_TOKEN=

# ── Google AI (direct mode — no Vertex) ──────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key

# ── Vertex AI (GCP mode — set GOOGLE_GENAI_USE_VERTEXAI=true) ────────────────
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Firestore ─────────────────────────────────────────────────────────────────
FIRESTORE_COLLECTION=vibe_sessions

# ── Vite / Frontend ───────────────────────────────────────────────────────────
VITE_LIVEKIT_URL=wss://your-livekit-host.livekit.cloud
VITE_LIVEKIT_TOKEN=
